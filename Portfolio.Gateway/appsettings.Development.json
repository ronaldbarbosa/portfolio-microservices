{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "KeyCloak": {
      "Authority": "http://localhost:8080/realms/portfolio",
      "Audience": "account",
      "RequireHttpsMetadata": false,
      "ValidateAudience": true,
      "ValidateIssuer": true,
      "ValidateLifetime": true,
      "ValidIssuers": [
        "http://localhost:8080/realms/portfolio"
      ]
    }
  },
  "yarp": {
    "Routes": {
      "projects": {
        "Match": { "Path": "/api/projects/{**catchall}" },
        "ClusterId": "projects",
        "AuthorizationPolicy": "authenticated"
      }
    },
    "Clusters": {
      "projects": {
        "Destinations": {
          "portfolio": { "Address": "http://localhost:5148" }
        }
      }
    }
  }
}
