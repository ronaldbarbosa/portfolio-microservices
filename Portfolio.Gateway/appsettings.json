{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [ "https://ronald-portfolio.vercel.app" ],
  "Authentication": {
    "KeyCloak": {
      "Authority": "http://localhost:8080/realms/portfolio",
      "Audience": "account",
      "RequireHttpsMetadata": false,
      "ValidateAudience": true,
      "ValidateIssuer": true,
      "ValidateLifetime": true,
      "ValidIssuers": [
        "http://localhost:8080/realms/portfolio"
      ]
    }
  },
  "yarp": {
    "Routes": {
      "projects": {
        "Match": {
          "Path": "/api/projects/{**catchall}"
        },
        "ClusterId": "projects",
        "AuthorizationPolicy": "authenticated"
      },
      "projects-swagger": {
        "Match": {
          "Path": "/swagger/{**catchall}"
        },
        "ClusterId": "projects"
      },
      "images": {
        "Match": {
          "Path": "/api/images/{**catchall}"
        },
        "ClusterId": "images",
        "AuthorizationPolicy": "authenticated"
      }
    },
    "Clusters": {
      "projects": {
        "Destinations": {
          "portfolio": {
            "Address": "http://localhost:5148"
          }
        }
      },
      "images": {
        "Destinations": {
          "portfolio": {
            "Address": "http://localhost:5231"
          }
        }
      }
    }
  }
}