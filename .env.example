# Docker Compose - Desenvolvimento local
# Execute: docker compose up -d

POSTGRES_DB=project_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Connection string para desenvolvimento local
DB_CONNECTION_STRING=Host=localhost;Database=project_service;Username=postgres;Password=postgres

# Porta da aplicação
PORT=8080

# Cloudinary - Image Uploader Service
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# RabbitMQ - Message Broker (CloudAMQP em produção)
RABBITMQ_CONNECTION_STRING=